# ──────────────────────────────────────────────────────────────────────────────
# n8n Core / Render Required (must match your Render service URL after deploy)
# ──────────────────────────────────────────────────────────────────────────────
WEBHOOK_URL=https://n8n-ultra-media-xxx.onrender.com/
N8N_HOST=n8n-ultra-media-xxx.onrender.com
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8n-ultra-media-xxx.onrender.com/
N8N_PROXY_HOPS=1
GENERIC_TIMEZONE=America/Los_Angeles                 # Or your timezone, e.g. Europe/Berlin

# ──────────────────────────────────────────────────────────────────────────────
# Binary Data Storage (filesystem for free tier safety; use rclone in workflows for B2)
# ──────────────────────────────────────────────────────────────────────────────
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
# If you later upgrade to paid plan + want native S3/B2 external storage:
# N8N_AVAILABLE_BINARY_DATA_MODES=filesystem,s3
# N8N_DEFAULT_BINARY_DATA_MODE=s3
# N8N_EXTERNAL_STORAGE_S3_HOST=s3.us-west-000.backblazeb2.com
# N8N_EXTERNAL_STORAGE_S3_BUCKET_NAME=your-bucket-name
# N8N_EXTERNAL_STORAGE_S3_BUCKET_REGION=us-west-000
# N8N_EXTERNAL_STORAGE_S3_ACCESS_KEY=your-key-id
# N8N_EXTERNAL_STORAGE_S3_ACCESS_SECRET=your-app-key

# ──────────────────────────────────────────────────────────────────────────────
# Backblaze B2 (used by rclone in Execute Command nodes / entrypoint auto-config)
# ──────────────────────────────────────────────────────────────────────────────
BACKBLAZE_KEY_ID=your-key-id-here
BACKBLAZE_APP_KEY=your-app-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Recommended / Production Best Practices (add as needed)
# ──────────────────────────────────────────────────────────────────────────────
N8N_LOG_LEVEL=info                                   # debug for troubleshooting
N8N_ENCRYPTION_KEY=super-secure-random-32-chars-here # generate once, never change!
PORT=5678                                            # n8n listens here (Render auto-detects)
NODE_OPTIONS=--max-old-space-size=4096               # Helps with heavy media processing

# Executions / Resource Tuning (free tier limits; tune lower if OOM)
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168                          # hours (7 days)
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none                 # save space on free Postgres

# Optional Security / Features
N8N_DIAGNOSTICS_ENABLED=false                        # disable telemetry
N8N_BLOCK_ENV_ACCESS_IN_NODE=true                    # security: block $env in nodes
NODES_INCLUDE=n8n-nodes-base.executeCommand          # enable shell commands (careful!)

# Timezone fallback (some nodes use TZ)
TZ=America/Los_Angeles
